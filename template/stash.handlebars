name: "{{@package 'displayName'}}"
desc: |-
  {{#each (split (@package 'description') "\n")}}
  {{{this}}}
  {{/each}}
openUrl: "{{@package 'openUrl'}}"
author: |-
  {{#each (@package 'contributors')}}
  {{this}}
  {{/each}}
homepage: "{{@package 'homepage'}}"
icon: "{{@package 'icon'}}"
category: "{{@package 'organizationName'}}"
date: "{{now "yyyy-MM-dd HH:mm:ss"}}"
version: "{{@package 'version'}}"

rules:
  - DOMAIN,weather-analytics-events.apple.com,REJECT-DROP
  - DOMAIN-SUFFIX,tthr.apple.com,REJECT-DROP
  - DOMAIN,tether.edge.apple,REJECT-DROP
  - AND,((OR,((IP-ASN,714,no-resolve),(IP-ASN,6185,no-resolve))),(PROTOCOL,QUIC)),REJECT-DROP

http:
  mitm:
    - "weatherkit.apple.com"
  script:
    - match: ^https?:\/\/weatherkit\.apple\.com\/api\/v1\/airQualityScale\/
      name: WeatherKit.api.airQualityScale.request
      type: request
      argument:
    - match: ^https?:\/\/weatherkit\.apple\.com\/api\/v[123]\/availability\/
      name: WeatherKit.api.availability.request
      type: request
      argument:
    - match: ^https?:\/\/weatherkit\.apple\.com\/api\/v[23]\/weather\/
      name: WeatherKit.api.weather.request
      type: request
      argument:
    - match: ^https?:\/\/weatherkit\.apple\.com\/api\/v[123]\/availability\/
      name: WeatherKit.api.availability.response
      type: response
      require-body: true
      argument:
    - match: ^https?:\/\/weatherkit\.apple\.com\/api\/v1\/severeWeatherNotificationChannels\/global$
      name: WeatherKit.api.severeWeatherNotificationChannels.response
      type: response
      require-body: true
      argument:
    - match: ^https?:\/\/weatherkit\.apple\.com\/api\/v[23]\/weather\/
      name: WeatherKit.api.weather.response
      type: response
      require-body: true
      binary-mode: true
      argument:

script-providers:
  WeatherKit.api.airQualityScale.request:
    url: https://github.com/wuchunkei/weather-kit/releases/download/v{{@package 'version'}}/request.bundle.js
    interval: 86400
  WeatherKit.api.availability.request:
    url: https://github.com/wuchunkei/weather-kit/releases/download/v{{@package 'version'}}/request.bundle.js
    interval: 86400
  WeatherKit.api.weather.request:
    url: https://github.com/wuchunkei/weather-kit/releases/download/v{{@package 'version'}}/request.bundle.js
    interval: 86400
  WeatherKit.api.availability.response:
    url: https://github.com/wuchunkei/weather-kit/releases/download/v{{@package 'version'}}/response.bundle.js
    interval: 86400
  WeatherKit.api.severeWeatherNotificationChannels.response:
    url: https://github.com/wuchunkei/weather-kit/releases/download/v{{@package 'version'}}/response.bundle.js
    interval: 86400
  WeatherKit.api.weather.response:
    url: https://github.com/wuchunkei/weather-kit/releases/download/v{{@package 'version'}}/response.bundle.js
    interval: 86400
