[Argument]
{{{arguments}}}

[Rule]
DOMAIN,weather-analytics-events.apple.com,REJECT-DROP
DOMAIN-SUFFIX,tthr.apple.com,REJECT-DROP
DOMAIN,tether.edge.apple,REJECT-DROP
AND,((OR,((IP-ASN,714,no-resolve),(IP-ASN,6185,no-resolve))),(PROTOCOL,QUIC)),REJECT-DROP

[Script]
http-request ^https?:\/\/weatherkit\.apple\.com\/api\/v[123]\/availability\/ script-path=https://github.com/wuchunkei/weather-kit/releases/download/v{{@package 'version'}}/request.bundle.js, tag=🌤 WeatherKit.api.availability.request, argument={{{scriptParams}}}
http-request ^https?:\/\/weatherkit\.apple\.com\/api\/v[23]\/weather\/ script-path=https://github.com/wuchunkei/weather-kit/releases/download/v{{@package 'version'}}/request.bundle.js, tag=🌤 WeatherKit.api.weather.request, argument={{{scriptParams}}}
http-response ^https?:\/\/weatherkit\.apple\.com\/api\/v[123]\/availability\/ requires-body=1, script-path=https://github.com/wuchunkei/weather-kit/releases/download/v{{@package 'version'}}/response.bundle.js, tag=🌤 WeatherKit.api.availability.response, argument={{{scriptParams}}}
http-response ^https?:\/\/weatherkit\.apple\.com\/api\/v[23]\/weather\/ requires-body=1, binary-body-mode=1, script-path=https://github.com/wuchunkei/weather-kit/releases/download/v{{@package 'version'}}/response.bundle.js, tag=🌤 WeatherKit.api.weather.response, argument={{{scriptParams}}}

[MITM]
hostname = weatherkit.apple.com
